<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="400.0" prefWidth="400.0" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="todolist.FXMLFormularioTareaController">
   <children>
      <Label fx:id="lbTituloPantalla" layoutX="40.0" layoutY="20.0" text="Formulario de Tarea">
         <font>
            <Font name="System Bold" size="20.0" />
         </font>
      </Label>
      
      <Label layoutX="40.0" layoutY="70.0" text="Título de la tarea (*):" />
      <TextField fx:id="tfTitulo" layoutX="40.0" layoutY="90.0" prefHeight="25.0" prefWidth="320.0" promptText="Ej. Hacer las compras" />
      
      <Label layoutX="40.0" layoutY="130.0" text="Descripción:" />
      <TextArea fx:id="taDescripcion" layoutX="40.0" layoutY="150.0" prefHeight="80.0" prefWidth="320.0" promptText="Detalles adicionales de la tarea..." wrapText="true" />
      
      <Label layoutX="40.0" layoutY="250.0" text="Fecha a realizar (*):" />
      <DatePicker fx:id="dpFechaRealizar" editable="false" layoutX="40.0" layoutY="270.0" prefHeight="25.0" prefWidth="320.0" promptText="Seleccione una fecha" />
      
      <Label fx:id="lbError" layoutX="40.0" layoutY="310.0" prefHeight="17.0" prefWidth="320.0" textFill="RED" />
      
      <Button layoutX="100.0" layoutY="345.0" mnemonicParsing="false" onAction="#clicGuardar" prefHeight="25.0" prefWidth="90.0" text="Guardar" />
      <Button layoutX="210.0" layoutY="345.0" mnemonicParsing="false" onAction="#clicCancelar" prefHeight="25.0" prefWidth="90.0" text="Cancelar" />
   </children>
</AnchorPane>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="400.0" prefWidth="400.0" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="todolist.FXMLInicioSesionController">
   <children>
      <Label layoutX="123.0" layoutY="50.0" text="Iniciar Sesión">
         <font>
            <System name="System Bold" size="24.0" />
         </font>
      </Label>
      <Label layoutX="70.0" layoutY="116.0" text="RFC:" />
      <TextField fx:id="tfRfc" layoutX="70.0" layoutY="140.0" prefHeight="25.0" prefWidth="260.0" promptText="Ingrese su RFC" />
      <Label layoutX="70.0" layoutY="188.0" text="Contraseña:" />
      <PasswordField fx:id="pfPassword" layoutX="70.0" layoutY="212.0" prefHeight="25.0" prefWidth="260.0" promptText="Ingrese su contraseña" />
      <Label fx:id="lbError" layoutX="70.0" layoutY="245.0" textFill="RED" />
      <Button layoutX="155.0" layoutY="276.0" mnemonicParsing="false" onAction="#clicIniciarSesion" prefHeight="25.0" prefWidth="91.0" text="Ingresar" />
      <Button layoutX="155.0" layoutY="318.0" mnemonicParsing="false" onAction="#clicIrRegistro" prefHeight="25.0" prefWidth="91.0" text="Registrarse" />
   </children>
</AnchorPane>
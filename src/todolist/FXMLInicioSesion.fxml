<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="400.0" style="-fx-background-color: #172B4D;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="todolist.FXMLInicioSesionController">
   <children>
      <Label layoutX="123.0" layoutY="50.0" text="Iniciar Sesión" textFill="WHITE">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>
      
      <Label layoutX="70.0" layoutY="116.0" text="RFC:" textFill="#EBECF0">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>
      <TextField fx:id="tfRfc" layoutX="70.0" layoutY="140.0" prefHeight="30.0" prefWidth="260.0" promptText="Ingrese su RFC" style="-fx-background-color: #ffffff; -fx-text-fill: #172B4D; -fx-border-radius: 3px;" />
      
      <Label layoutX="70.0" layoutY="188.0" text="Contraseña:" textFill="#EBECF0">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>
      <PasswordField fx:id="pfPassword" layoutX="70.0" layoutY="212.0" prefHeight="30.0" prefWidth="260.0" promptText="Ingrese su contraseña" style="-fx-background-color: #ffffff; -fx-text-fill: #172B4D; -fx-border-radius: 3px;" />
      
      <Label fx:id="lbError" layoutX="70.0" layoutY="245.0" prefHeight="17.0" prefWidth="260.0" textFill="#FF8C8C">
         <font>
            <Font name="System Italic" size="11.0" />
         </font>
      </Label>
      
      <Button layoutX="125.0" layoutY="276.0" mnemonicParsing="false" onAction="#clicIniciarSesion" prefHeight="30.0" prefWidth="150.0" style="-fx-background-color: #5AAC44; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Ingresar" />
      <Button layoutX="125.0" layoutY="320.0" mnemonicParsing="false" onAction="#clicIrRegistro" prefHeight="30.0" prefWidth="150.0" style="-fx-background-color: #ffffff; -fx-text-fill: #172B4D; -fx-font-weight: bold; -fx-cursor: hand;" text="Registrarte" />
   </children>
</AnchorPane>